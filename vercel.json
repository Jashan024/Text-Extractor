{
    "builds": [
        { "src": "app.py", "use": "@vercel/python" },
        { "src": "static/**", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/static/(.*)", "dest": "/static/$1" },
        { "src": "/(.*)", "dest": "/app.py" }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'self' https://gleel2.com https://*.gleel2.com"
                }
            ]
        }
    ]
}
